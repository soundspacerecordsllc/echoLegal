# Legal Updates Feature - Environment Variables

# Supabase (optional - falls back to local JSON in development)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# Congress.gov API (required for Congress updates)
# Get your API key at: https://api.congress.gov/sign-up/
CONGRESS_API_KEY=your-congress-api-key

# Admin Authentication (required for admin panel)
ADMIN_USER=admin
ADMIN_PASS=your-secure-password

# Vercel Cron Secret (automatically set by Vercel)
# CRON_SECRET=your-cron-secret

# ─── FilingControl Billing (Stripe) ─────────────────────────────────
# Required for /api/filingcontrol/billing/* endpoints
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
FC_STRIPE_PRICE_PRO=price_...

# Optional overrides (defaults to /filingcontrol/dashboard with query params)
# FC_STRIPE_SUCCESS_URL=https://your-domain.com/filingcontrol/dashboard?upgraded=1
# FC_STRIPE_CANCEL_URL=https://your-domain.com/filingcontrol/dashboard?upgrade=cancel

# Public keys (used client-side)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
